<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1300</width>
    <height>850</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>1000</width>
    <height>700</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>SpeechEQ v1.0</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
          /* Глобальные стили */
          QMainWindow {
              background-color: #f5f7fa;
          }
          
          QLabel {
              color: #2c3e50;
          }
          
          QGroupBox {
              font-weight: bold;
              border: 1px solid #d0d7de;
              border-radius: 8px;
              margin-top: 12px;
              padding-top: 12px;
              background-color: #ffffff;
          }
          
          QGroupBox::title {
              subcontrol-origin: margin;
              left: 16px;
              padding: 0 8px 0 8px;
              color: #1f2d3d;
          }
          
          QPushButton {
              background-color: #ffffff;
              border: 1.5px solid #cbd5e1;
              border-radius: 8px;
              padding: 8px 20px;
              font-weight: 500;
              font-size: 13px;
              color: #1f2d3d;
          }
          
          QPushButton:hover {
              background-color: #f1f5f9;
              border-color: #94a3b8;
          }
          
          QPushButton:pressed {
              background-color: #e2e8f0;
          }
          
          QPushButton#actionBtn {
              background-color: #3b82f6;
              border: 1.5px solid #3b82f6;
              color: white;
              font-size: 14px;
              font-weight: bold;
          }
          
          QPushButton#actionBtn:hover {
              background-color: #2563eb;
              border-color: #2563eb;
          }
          
          QPushButton#clearQueueBtn, QPushButton#cancelSelectedBtn {
              background-color: #ef4444;
              border: 1.5px solid #ef4444;
              color: white;
              font-size: 14px;
              font-weight: bold;
          }
          
          QPushButton#clearQueueBtn:hover, QPushButton#cancelSelectedBtn:hover {
              background-color: #dc2626;
              border-color: #dc2626;
          }
          
          QPushButton#openLogBtn {
              background-color: #f1f5f9;
              border-color: #cbd5e1;
              color: #475569;
              font-size: 12px;
              padding: 6px 16px;
          }
          
          QPushButton#openLogBtn:hover {
              background-color: #e2e8f0;
              border-color: #94a3b8;
              color: #1f2d3d;
          }
          
          /* Стили для QLineEdit */
          QLineEdit {
              border: 1px solid #cbd5e1;
              border-radius: 6px;
              padding: 8px 10px;
              background-color: #ffffff;
              selection-background-color: #3b82f6;
              font-size: 12px;
              color: #1f2d3d;
          }
          
          QLineEdit:focus {
              border-color: #3b82f6;
              outline: none;
          }
          
          /* Стили для QListWidget */
          QListWidget {
              border: 1px solid #cbd5e1;
              border-radius: 6px;
              padding: 8px 10px;
              background-color: #ffffff;
              selection-background-color: #3b82f6;
              selection-color: #ffffff;
              font-size: 12px;
              color: #1f2d3d;
          }
          
          QListWidget::item {
              color: #1f2d3d;
              padding: 5px;
          }
          
          QListWidget::item:selected {
              background-color: #3b82f6;
              color: #ffffff;
          }
          
          QListWidget::item:hover {
              background-color: #f1f5f9;
              color: #1f2d3d;
          }
          
          QListWidget:focus {
              border-color: #3b82f6;
              outline: none;
          }
          
          /* Стили для QTableWidget */
          QTableWidget {
              border: 1px solid #cbd5e1;
              border-radius: 6px;
              background-color: #ffffff;
              alternate-background-color: #f8fafc;
              gridline-color: #e2e8f0;
              font-size: 12px;
          }
          
          QTableWidget::item {
              padding: 8px;
          }
          
          QTableWidget::item:selected,
          QTableWidget::item:selected:active,
          QTableWidget::item:selected:focus,
          QTableWidget::item:selected:!active {
              background-color: #3b82f6 !important;
              color: #ffffff !important;
          }
          
          QTableWidget::item:hover {
              background-color: #f1f5f9;
          }
          
          QTableWidget:focus {
              border-color: #3b82f6;
              outline: none;
          }
          
          QHeaderView::section {
              background-color: #f1f5f9;
              padding: 10px;
              border: none;
              border-bottom: 1px solid #e2e8f0;
              font-weight: bold;
              color: #1e293b;
              font-size: 12px;
          }
          
          /* Стили для QProgressBar */
          QProgressBar {
              border: 1px solid #cbd5e1;
              background-color: #f1f5f9;
              border-radius: 4px;
              text-align: center;
              color: #1f2d3d;
              height: 20px;
              font-size: 11px;
          }
          
          QProgressBar::chunk {
              background-color: #3b82f6;
              border-radius: 3px;
          }
          
          /* ===== СТИЛИ ДЛЯ QComboBox ===== */
          QComboBox {
              border: 1px solid #cbd5e1;
              border-radius: 6px;
              padding: 8px 28px 8px 12px;
              background-color: #ffffff;
              color: #1f2d3d;
              font-size: 12px;
              min-height: 20px;
          }
          
          QComboBox:hover {
              border-color: #94a3b8;
          }
          
          QComboBox:focus, QComboBox:open {
              border-color: #3b82f6;
              outline: none;
          }
          
          QComboBox::drop-down {
              border: none;
              width: 28px;
              background: transparent;
          }
          
          QComboBox QAbstractItemView {
              border: 1px solid #cbd5e1;
              border-radius: 8px;
              background-color: #ffffff;
              selection-background-color: #3b82f6;
              selection-color: #ffffff;
              color: #1f2d3d;
              outline: none;
              padding: 4px;
          }
          
          QComboBox QAbstractItemView::item {
              padding: 8px 10px;
              min-height: 22px;
              margin: 2px;
              border-radius: 6px;
              background-color: transparent;
              color: #1f2d3d;
          }
          
          QComboBox QAbstractItemView::item:hover {
              background-color: #eff6ff;
              color: #1e293b;
          }
          
          QComboBox QAbstractItemView::item:selected {
              background-color: #3b82f6;
              color: #ffffff;
          }
          
          QComboBox QAbstractItemView::item:selected:hover {
              background-color: #2563eb;
              color: #ffffff;
          }
          
          QComboBox QScrollBar:vertical {
              background: transparent;
              width: 10px;
              margin: 4px 4px 4px 0px;
              border: none;
          }
          
          QComboBox QScrollBar::handle:vertical {
              background: #cbd5e1;
              min-height: 24px;
              border-radius: 5px;
          }
          
          QComboBox QScrollBar::handle:vertical:hover {
              background: #94a3b8;
          }
          
          QComboBox QScrollBar::add-line:vertical,
          QComboBox QScrollBar::sub-line:vertical {
              height: 0px;
              border: none;
              background: transparent;
          }
          
          QComboBox QScrollBar::add-page:vertical,
          QComboBox QScrollBar::sub-page:vertical {
              background: transparent;
          }
          
          /* ===== СТИЛИ ДЛЯ QSpinBox ===== */
          QSpinBox {
              border: 1px solid #cbd5e1;
              border-radius: 6px;
              padding: 0 26px 0 10px;
              min-height: 36px;
              background-color: #ffffff;
              selection-background-color: #3b82f6;
              font-size: 12px;
              color: #1f2d3d;
          }
          
          QSpinBox:focus {
              border-color: #3b82f6;
              outline: none;
          }
          
          QSpinBox::up-button {
              subcontrol-origin: border;
              subcontrol-position: top right;
              width: 22px;
              height: 18px;
          }
          
          QSpinBox::down-button {
              subcontrol-origin: border;
              subcontrol-position: bottom right;
              width: 22px;
              height: 18px;
          }
          
          /* Стили для QSlider */
          QSlider::groove:horizontal {
              border: none;
              height: 5px;
              background: #e2e8f0;
              border-radius: 3px;
          }
          
          QSlider::handle:horizontal {
              background: #3b82f6;
              width: 16px;
              height: 16px;
              margin: -5px 0;
              border-radius: 8px;
              border: 1px solid #3b82f6;
          }
          
          QSlider::handle:horizontal:hover {
              background: #2563eb;
          }
          
          QSlider::sub-page:horizontal {
              background: #3b82f6;
              border-radius: 3px;
          }
          
          /* Стили для QCheckBox */
          QCheckBox {
              spacing: 10px;
              color: #1f2d3d;
              font-size: 12px;
          }
          
          QCheckBox::indicator {
              width: 18px;
              height: 18px;
              border-radius: 4px;
              border: 1.5px solid #cbd5e1;
              background-color: #ffffff;
          }
          
          QCheckBox::indicator:checked {
              background-color: #3b82f6;
              border-color: #3b82f6;
          }
          
          QCheckBox::indicator:checked:hover {
              background-color: #2563eb;
          }
          
          QCheckBox::indicator:unchecked:hover {
              border-color: #94a3b8;
          }
          
          QCheckBox::indicator:disabled {
              background-color: #f1f5f9;
              border-color: #e2e8f0;
          }
          
          /* Навигационная панель */
          #navWidget {
              background-color: #ffffff;
              border-top: 1px solid #e2e8f0;
              border-bottom: 1px solid #e2e8f0;
          }
          
          #navWidget QPushButton {
              background-color: transparent;
              border: 1.5px solid transparent;
              padding: 14px 24px;
              font-weight: 600;
              font-size: 14px;
              color: #475569;
          }
          
          #navWidget QPushButton:hover {
              color: #3b82f6;
              border-color: #3b82f6;
              background-color: #f8fafc;
          }
    </string>
  </property>
